<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
        "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
        "https://checkstyle.org/dtds/configuration_1_3.dtd">
<module name="Checker">
    <property name="charset" value="UTF-8"/>
    <property name="severity" value="warning"/>
    <property name="fileExtensions" value="java"/>

    <module name="TreeWalker">
        <module name="AvoidStarImport">
            <property name="excludes" value="org.springframework.web.bind.annotation.*,org.apache.ibatis.annotations.*,io.jsonwebtoken.*,java.io.*,java.net.*,java.lang.Math"/>
        </module>
        <module name="UnusedImports"/>
        <module name="NeedBraces">
            <property name="tokens" value="LITERAL_DO,LITERAL_ELSE,LITERAL_FOR,LITERAL_IF,LITERAL_WHILE"/>
        </module>
        <module name="MagicNumber">
            <property name="ignoreNumbers" value="-1,0,1,2,3,4,5,6,7,10,15,20,30,60,100,365,3650,1000,1024,2000,3600,86400"/>
        </module>
    </module>
</module>